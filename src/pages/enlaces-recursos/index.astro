---
import BaseLayout from "@layouts/BaseLayout.astro";
import ImportantLinksView from "./_components/ImportantLinksView.astro";
import { db } from "../../db";
import type { CategoryTone, CategoryViewModel } from "./_components/types";

const rawCategories = await db.query.resourceCategories.findMany({
  with: {
    links: true,
  },
});

const importantCategories = rawCategories.map(
  (category): CategoryViewModel => ({
    id: category.id,
    category: category.title,
    icon: category.iconName as unknown as `boxicons:${string}`,
    tone: (category.tone || "primary") as CategoryTone,
    links: category.links.map((link) => ({
      ...link,
      subtitle: link.subtitle ?? undefined,
    })),
  }),
);
---

<BaseLayout>
  <ImportantLinksView categories={importantCategories} />
</BaseLayout>
