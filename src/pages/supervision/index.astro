---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import PageContainer from "@components/ui/PageContainer.astro";
import PageHeader from "@components/ui/PageHeader.astro";

const supervisionTools = [
  {
    title: "Cronograma",
    description: "Gestión integral de asistencia y modalidades del equipo.",
    icon: "boxicons:calendar-filled",
    href: "/cronograma",
  },
  {
    title: "Calidad de operadores",
    description: "Métricas y validaciones de la calidad de atención del equipo de operaciones.",
    icon: "boxicons:bar-chart-big-filled",
    href: "/calidad-operadores",
  },
];
---

<BaseLayout title="Supervisión">
  <PageContainer gap="lg" class="pb-8">
    <PageHeader
      title="Supervisión"
      description="Panel centralizado para herramientas de gestión de personal y métricas del equipo."
    />

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {supervisionTools.map((tool) => (
        <a
          href={tool.href}
          class="card border border-base-200 bg-base-100 text-left shadow-sm transition-all hover:border-primary hover:shadow-md focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 group"
        >
          <div class="card-body">
            <div class="mb-2 flex h-12 w-12 items-center justify-center rounded-xl bg-secondary/10 text-secondary transition-colors group-hover:bg-primary/10 group-hover:text-primary">
              <Icon name={tool.icon} class="size-6" />
            </div>
            <h2 class="card-title text-base-content transition-colors group-hover:text-primary">
              {tool.title}
            </h2>
            <p class="text-sm text-base-content/70">{tool.description}</p>
            <div class="card-actions mt-4 justify-end">
              <span class="flex items-center gap-1 text-sm font-medium text-primary">
                Acceder <Icon name="boxicons:arrow-right-stroke-filled" class="size-4" />
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </PageContainer>
</BaseLayout>
