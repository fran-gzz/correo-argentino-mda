---
import { db } from "@db/index";
import { offices } from "@db/schema";
import { eq } from "drizzle-orm";
import BaseLayout from "@layouts/BaseLayout.astro";
import { logAdminAction } from "@lib/auditLogger";
import AdminOfficesContent from "@components/admin/offices/AdminOfficesContent.astro";
import AdminOfficesSkeleton from "@components/admin/offices/AdminOfficesSkeleton.astro";

let successMsg = "";
let errorMsg = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = formData.get("action")?.toString();

  if (action === "delete_office") {
    const officeId = Number(formData.get("officeId"));
    if (officeId) {
      try {
        const [deleted] = await db
          .delete(offices)
          .where(eq(offices.id, officeId))
          .returning({ code: offices.code, name: offices.name });

        if (deleted) {
          successMsg = `Oficina "${deleted.name}" (${deleted.code}) eliminada con éxito.`;
          await logAdminAction(Astro.locals.user?.username || 'Sistema', `Eliminó la oficina "${deleted.name}" (${deleted.code})`);
        } else {
          errorMsg = "La oficina indicada no existe.";
        }
      } catch (e) {
        errorMsg = "Error al eliminar la oficina.";
      }
    }
  }
}

const searchParams = Astro.url.searchParams;

const typeFilter = searchParams.get("type") || "all";
const regionFilter = searchParams.get("region") || "all";
const provinceFilter = searchParams.get("province") || "all";
const zoneFilter = searchParams.get("zone") || "all";
const paqarFilter = searchParams.get("paqar") || "all";
const searchFilter = searchParams.get("search") || "";
---

<BaseLayout>
  <AdminOfficesContent
    server:defer
    successMsg={successMsg}
    errorMsg={errorMsg}
    typeFilter={typeFilter}
    regionFilter={regionFilter}
    provinceFilter={provinceFilter}
    zoneFilter={zoneFilter}
    paqarFilter={paqarFilter}
    searchFilter={searchFilter}
  >
    <AdminOfficesSkeleton slot="fallback" />
  </AdminOfficesContent>
</BaseLayout>
