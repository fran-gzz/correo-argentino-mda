---
import { db } from "@db/index";
import { agents, schedules } from "@db/schema";
import { eq } from "drizzle-orm";
import BaseLayout from "@layouts/BaseLayout.astro";
import { logAdminAction } from "@lib/auditLogger";
import AdminOperadoresContent from "@components/admin/operadores/AdminOperadoresContent.astro";
import AdminOperadoresSkeleton from "@components/admin/operadores/AdminOperadoresSkeleton.astro";

const base = import.meta.env.BASE_URL || "/";
const cleanBase = base.endsWith("/") ? base : base + "/";

const user = Astro.locals.user;
if (!user || !["admin", "supervisor"].includes(user.role)) return Astro.redirect(`${cleanBase}login`);

let successMsg = "";
let errorMsg = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = formData.get("action")?.toString();

  if (action === "delete_operator") {
    const operatorId = Number(formData.get("operatorId"));
    if (!isNaN(operatorId)) {
      try {
        const [deleted] = await db
          .delete(agents)
          .where(eq(agents.id, operatorId))
          .returning({ id: agents.id, name: agents.name });

        if (deleted) {
          // Also delete their schedule overrides
          await db.delete(schedules).where(eq(schedules.agentName, deleted.name));
          successMsg = `Operador "${deleted.name}" (${deleted.id}) eliminado con éxito.`;
          await logAdminAction(Astro.locals.user?.username || 'Sistema', `Eliminó el operador "${deleted.name}" (${deleted.id})`);
        } else {
          errorMsg = "El operador indicado no existe.";
        }
      } catch {
        errorMsg = "Error al eliminar el operador.";
      }
    }
  }
}
---

<BaseLayout>
  <AdminOperadoresContent server:defer successMsg={successMsg} errorMsg={errorMsg}>
    <AdminOperadoresSkeleton slot="fallback" />
  </AdminOperadoresContent>
</BaseLayout>
