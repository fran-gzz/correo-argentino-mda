---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Portal Mesa de Ayuda">
  <section class="mx-auto flex w-full max-w-4xl flex-col gap-6">
    <h1 class="text-3xl font-bold text-secondary">Portal Mesa de Ayuda</h1>

    <article class="card border border-base-300 bg-base-200 shadow-sm">
      <div class="card-body gap-3">
        <h2 class="card-title">Accesos operativos</h2>
        <p class="text-sm text-base-content/70">
          Ingreso rapido a los modulos principales para tareas de soporte N1 y
          N2.
        </p>
        <div class="card-actions justify-start gap-2">
          <a href="/titulos-tickets" class="btn btn-primary btn-sm">
            Titulos de tickets
          </a>
          <a href="/buscador-usuarios" class="btn btn-secondary btn-sm">
            Buscador de usuarios
          </a>
        </div>
      </div>
    </article>
  </section>
</BaseLayout>
