---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import SignatureGenerator from "./_components/SignatureGenerator.astro";
---

<BaseLayout title="Generador de Firmas - Correo Argentino">
  <div class="max-w-6xl mx-auto space-y-8">
    <PageHeader
      title="Generador de firmas"
      description="Completa tus datos laborales para generar y copiar tu firma institucional oficial."
    />

    <SignatureGenerator origin={Astro.url.origin} />
  </div>
</BaseLayout>
